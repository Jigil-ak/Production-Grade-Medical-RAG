# === Medical RAG Configuration ===
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# --- Groq API ---
GROQ_API_KEY=

# --- Storage ---
CHROMA_PERSIST_DIR=./data/processed/chroma

# --- Embedding ---
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2

# --- Observability ---
# LANGFUSE_HOST must point at cloud.langfuse.com ONLY.
# Self-hosted Langfuse requires Postgres + Docker daemon (~1.2GB RAM),
# which is a guaranteed OOM on the 4GB budget. This is a hard constraint,
# not a preference.
LANGFUSE_HOST=https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# --- Prompt Versioning ---
PROMPT_VERSION=answer_generation_v1

# --- Environment ---
# dev = ConsoleRenderer (human-readable logs)
# production = JSONRenderer (machine-parseable logs)
ENVIRONMENT=dev
